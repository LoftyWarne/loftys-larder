# Copy to .env and adjust as needed. The real .env is gitignored.

# Backend connection strings. The host port (5433) is non-default so it
# doesn't collide with a system Postgres on 5432.
DATABASE_URL=postgres://lofty:lofty@localhost:5433/lofty_dev
DATABASE_URL_TEST=postgres://lofty:lofty@localhost:5433/lofty_test

# Consumed by docker-compose.yml. The Postgres container always listens
# on 5432 internally; POSTGRES_HOST_PORT controls the host-side mapping.
POSTGRES_USER=lofty
POSTGRES_PASSWORD=lofty
POSTGRES_DB=lofty_dev
POSTGRES_HOST_PORT=5433
