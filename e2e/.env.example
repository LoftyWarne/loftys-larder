# Dedicated Postgres database for the e2e suite. The DB is wiped + reseeded
# before each spec, so do not point this at the dev database.
DATABASE_URL=postgres://lofty:lofty@localhost:5433/lofty_e2e

# Backend origin Playwright drives. Must match BETTER_AUTH_URL passed to the
# bundled backend; the suite expects same-origin SPA serving (STATIC_DIR set).
BASE_URL=http://127.0.0.1:3100

# Email the e2e signs in as. NOT included in MAGIC_LINK_ALLOWED_EMAILS, so the
# magic-link send is silently dropped by `withAllowList` while Better Auth
# still writes the verification row we read out of the DB.
E2E_EMAIL=e2e@example.com
