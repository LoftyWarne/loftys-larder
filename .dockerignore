# Source-control + tooling state
.git
.gitignore
.github

# Local environment
.env
.env.*
**/.env
**/.env.*
# ...except the committed frontend production env: it carries only the public
# Sentry DSN (baked into the SPA at build time, visible in DevTools — not a
# secret) and Vite must see it during `vite build`. Negation must follow the
# broad `.env.*` patterns above to take effect.
!frontend/.env.production

# Workspace installs and build output (Dockerfile rebuilds these)
node_modules
**/node_modules
**/dist
**/.tanstack
**/coverage
**/.vitest-cache

# Editor + OS noise
.idea
.vscode
.DS_Store

# Docs and infra files that don't belong in the image build context
docs
README.md
AGENTS.md
CLAUDE.md
docker
docker-compose.yml
fly.toml
.claude
.dockerignore
Dockerfile
