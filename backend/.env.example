NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://lofty:lofty@localhost:5433/lofty_dev

# Better Auth (FEAT-14). Secret must be ≥32 chars; generate with
# `openssl rand -base64 48`. BETTER_AUTH_URL is the backend origin used as the
# magic-link issuer; MAGIC_LINK_TRUSTED_ORIGIN is the frontend origin links
# point at and the only origin Better Auth trusts.
BETTER_AUTH_SECRET=please-replace-with-openssl-rand-base64-48
BETTER_AUTH_URL=http://localhost:3000
MAGIC_LINK_TRUSTED_ORIGIN=http://localhost:5173

# Resend (FEAT-13 verified the sender domain). The send fn is a thin fetch
# against api.resend.com/emails; MAGIC_LINK_FROM defaults to
# magic@loftys-larder.co.uk if unset.
RESEND_API_KEY=re_your_api_key
MAGIC_LINK_FROM=magic@loftys-larder.co.uk

# Allow-list gate (single-household MVP, DEC-17). Comma-separated emails;
# requests for any address not on the list are dropped without sending.
MAGIC_LINK_ALLOWED_EMAILS=you@example.com

# Cloudinary (DEC-50, DEC-68). API secret signs short-lived upload credentials;
# the browser uploads directly to Cloudinary, so the backend never sees image
# bytes. In production these are managed via `flyctl secrets`.
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Axiom log ingest (DEC-75 / FEAT-44). Required in production; unset locally
# leaves logs on stdout. Managed via `flyctl secrets` in prod. AXIOM_ENDPOINT
# overrides the API base for EU regions or test doubles; defaults to
# https://api.axiom.co.
AXIOM_TOKEN=
AXIOM_DATASET=
# AXIOM_ENDPOINT=https://api.axiom.co

# Sentry error tracking (DEC-76 / FEAT-45). Optional everywhere; an unset
# DSN no-ops the SDK init. SENTRY_ENVIRONMENT defaults to NODE_ENV.
# SENTRY_TRACES_SAMPLE_RATE defaults to 0 — traces are explicitly off until
# distributed tracing earns its cost (DEC-77).
SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0
